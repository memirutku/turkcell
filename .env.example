# ============================================
# Turkcell AI-Gen - Environment Configuration
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_VOICE_LIVE_ENABLED=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Milvus ---
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=turkcell_documents

# --- Milvus Dependencies ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Google Gemini (Phase 2+) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Gemini Live API (Real-time Voice) ---
GEMINI_LIVE_ENABLED=false
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Kore

# --- AWS (Phase 7+) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# --- MCP Server (Personalization) ---
MCP_ENABLED=true
MCP_API_KEY=

# --- LangSmith (Optional - Phase 2+) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=turkcell-ai-gen
